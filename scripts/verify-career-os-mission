#!/usr/bin/env node
const { spawnSync } = require('node:child_process');
const { existsSync } = require('node:fs');
const path = require('node:path');

(async () => {
  const {
    appRoot,
    defaultProductionStatusUrl,
    evaluateStatusApiEvidence,
    fetchProductionStatusEvidence,
    formatRows,
    repoRoot,
  } = await import('./career-os-mission-lib.mjs');

  const rows = [];
  const add = (name, passed, detail = '') => rows.push({ name, passed: Boolean(passed), detail });
  const localTsc = path.join(appRoot, 'node_modules', '.bin', process.platform === 'win32' ? 'tsc.cmd' : 'tsc');

  function run(name, command, args, cwd, timeout = 180000) {
    const result = spawnSync(command, args, {
      cwd,
      encoding: 'utf8',
      env: { ...process.env, NEXT_TELEMETRY_DISABLED: '1' },
      stdio: 'pipe',
      timeout,
    });
    add(name, result.status === 0, result.status === 0 ? '' : compact(result.stderr || result.stdout || result.error?.message || `${command} failed`));
    return result.status === 0;
  }

  add('AGENTS.md installed', existsSync(path.join(repoRoot, 'AGENTS.md')));
  for (const doc of [
    'CAREER_OS_MISSION.md',
    'CAREER_OS_ARCHITECTURE.md',
    'VERIFIED_PROFILE_AND_EVIDENCE_RULES.md',
    'EMPLOYER_AUTOMATION_BOUNDARIES.md',
    'CAREER_OS_ACCEPTANCE_CRITERIA.md',
    'CODEX_COST_CONTROL.md',
  ]) {
    add(`docs/${doc} exists`, existsSync(path.join(repoRoot, 'docs', doc)));
  }
  add('Synthetic fixture set exists', existsSync(path.join(repoRoot, 'fixtures', 'synthetic-career-os', 'pilot-evidence.json')));

  run('Acceptance tests pass', 'node', ['--test', 'tests/acceptance/career-os-contract.test.mjs'], repoRoot);
  run('Career OS source lint passes', 'npm', ['run', 'lint'], appRoot);
  run('TypeScript type check passes', localTsc, ['--noEmit', '--incremental', 'false'], appRoot);
  run('Next production build passes', 'npx', ['-y', 'node@20', 'node_modules/next/dist/bin/next', 'build'], appRoot, 600000);

  const statusUrl = process.env.CAREER_OS_VERIFY_URL || defaultProductionStatusUrl;
  try {
    const statusPayload = await fetchProductionStatusEvidence(statusUrl);
    add('Production status API reachable', true, statusUrl);
    for (const row of evaluateStatusApiEvidence(statusPayload)) rows.push(row);
  } catch (error) {
    add('Production status API reachable', false, compact(error instanceof Error ? error.message : String(error)));
  }

  console.log('Career OS mission verification');
  console.log(formatRows(rows));

  const failed = rows.filter((row) => !row.passed);
  if (failed.length) {
    console.error(`\n${failed.length} criterion/criteria failed. Production mission completion is not established.`);
    process.exit(1);
  }

  console.log('\nAll Career OS mission criteria passed with production evidence.');
})();

function compact(value) {
  return String(value).split('\n').map((line) => line.trim()).filter(Boolean).slice(-4).join(' | ');
}
